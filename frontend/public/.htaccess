# =================================================================
# Logix Finance — Apache .htaccess for BigRock / cPanel (shared host)
# =================================================================
# This file enables:
#  1. React Router SPA deep-linking (refresh on /about, /policies/*, etc.)
#  2. HTTPS redirect
#  3. Sensible caching for static assets
#  4. Gzip / Brotli compression where supported
#  5. Basic security headers
# =================================================================

Options -MultiViews
RewriteEngine On

# ---------- Force HTTPS (optional but recommended once SSL is on) ----------
# Comment the next 2 lines out during initial testing if SSL is not yet active.
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ---------- SPA fallback for React Router ----------
# Any request that is NOT a real file or directory is rewritten to index.html
# so the React app can handle the route on the client side.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/contact\.php$
RewriteRule ^ index.html [L]

# ---------- Caching ----------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault                              "access plus 1 month"
    ExpiresByType text/html                     "access plus 0 seconds"
    ExpiresByType text/css                      "access plus 1 year"
    ExpiresByType application/javascript        "access plus 1 year"
    ExpiresByType application/x-javascript      "access plus 1 year"
    ExpiresByType image/png                     "access plus 1 year"
    ExpiresByType image/jpg                     "access plus 1 year"
    ExpiresByType image/jpeg                    "access plus 1 year"
    ExpiresByType image/webp                    "access plus 1 year"
    ExpiresByType image/svg+xml                 "access plus 1 year"
    ExpiresByType font/woff                     "access plus 1 year"
    ExpiresByType font/woff2                    "access plus 1 year"
    ExpiresByType image/x-icon                  "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    # Prevent caching of index.html so updated builds load immediately
    <FilesMatch "index\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    # Long cache for hashed static assets under /static/
    <FilesMatch "\.(js|css|woff|woff2|png|jpg|jpeg|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# ---------- Compression ----------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json application/xml image/svg+xml font/woff font/woff2
</IfModule>

# ---------- Security headers ----------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ---------- Custom 404 / 500 (optional) ----------
ErrorDocument 404 /index.html

# ---------- Hide hidden files ----------
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
